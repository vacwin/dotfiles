#!/bin/bash

edp_enable() {
    hyprctl keyword monitor "eDP-1, 1920x1080@59.98, 0x0, 1.5"
}

edp_disable() {
    hyprctl keyword monitor "eDP-1, disable"
}

has_dp() {
    hyprctl monitors all | grep -q "^Monitor DP-"
}

lid_closed() {
    grep -q "closed" /proc/acpi/button/lid/LID0/state 2>/dev/null \
        || grep -q "closed" /proc/acpi/button/lid/LID/state 2>/dev/null
}

handle() {
    case $1 in
        monitoradded*)
            sleep 0.5
            if has_dp; then
                active_ws=$(hyprctl activeworkspace | awk 'NR==1{print $3}')
                edp_disable
                sleep 0.3
                dp=$(hyprctl monitors all | grep "^Monitor DP-" | head -1 | awk '{print $2}')
                hyprctl dispatch moveworkspacetomonitor "$active_ws $dp"
                hyprctl dispatch workspace "$active_ws"
            fi
            ;;
        monitorremoved*)
            sleep 0.5
            if ! has_dp; then
                if lid_closed; then
                    systemctl suspend
                else
                    edp_enable
                fi
            fi
            ;;
    esac
}

case "$1" in
    close)
        if has_dp; then
            edp_disable
        else
            systemctl suspend
        fi
        ;;
    open)
        edp_enable
        sleep 0.3
        hyprctl dispatch dpms on eDP-1
        ;;
    watch)
        if lid_closed; then
            sleep 2
            "$0" close
        fi
        runtime_dir="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"
        sock="$runtime_dir/hypr/$HYPRLAND_INSTANCE_SIGNATURE/.socket2.sock"
        [ -S "$sock" ] || sock="/tmp/hypr/$HYPRLAND_INSTANCE_SIGNATURE/.socket2.sock"
        socat - "UNIX-CONNECT:$sock" \
            | while read -r line; do handle "$line"; done
        ;;
esac
