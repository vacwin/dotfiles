#!/bin/bash

edp_enable() {
    hyprctl keyword monitor "eDP-1, 1920x1080@59.98, 0x0, 1.5"
}

edp_disable() {
    hyprctl keyword monitor "eDP-1, disable"
}

has_dp() {
    hyprctl monitors all | grep -q "^Monitor DP-"
}

handle() {
    case $1 in
        monitoradded*)
            sleep 0.5
            has_dp && edp_disable
            ;;
        monitorremoved*)
            sleep 0.5
            has_dp || edp_enable
            ;;
    esac
}

case "$1" in
    close)
        if has_dp; then
            edp_disable
        else
            systemctl suspend
        fi
        ;;
    open)
        edp_enable
        ;;
    watch)
        lid_state=$(cat /proc/acpi/button/lid/LID0/state 2>/dev/null \
                 || cat /proc/acpi/button/lid/LID/state 2>/dev/null)
        if echo "$lid_state" | grep -q "closed"; then
            sleep 2
            "$0" close
        fi
        socat - "UNIX-CONNECT:/tmp/hypr/$HYPRLAND_INSTANCE_SIGNATURE/.socket2.sock" \
            | while read -r line; do handle "$line"; done
        ;;
esac
