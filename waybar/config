{
    "layer": "top",
    "height": 34,
    "spacing": 4,
    "modules-left": [
        "hyprland/workspaces",
        "hyprland/window"
    ],
    "modules-center": [
        "clock"
    ],
    "modules-right": [
        "hyprland/submap",
        "wireplumber",
        "backlight",
        "bluetooth",
        "network",
        "battery",
        "hyprland/language",
        "custom/notification",
        "tray"
    ],
    "hyprland/workspaces": {
        "format": "{id}",
        "on-click": "activate"
    },
    "hyprland/window": {
        "max-length": 60,
        "separate-outputs": true
    },
    "hyprland/submap": {
        "format": "蟀毦 {}",
        "max-length": 12,
        "tooltip": false
    },
    "hyprland/language": {
        "format": "{short}"
    },
    "clock": {
        "format": "蟀 {:%a, %d %b  %I:%M %p}",
        "tooltip-format": "<tt><small>{calendar}</small></tt>",
        "calendar": {
            "format": {
                "today": "<span color='#7e9cd8'><b>{}</b></span>"
            }
        },
        "format-alt": "{:%Y-%m-%d}"
    },
    "battery": {
        "interval": 60,
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{capacity}% {icon}",
        "format-charging": "{capacity}% {icon}",
        "format-plugged": "{capacity}% 蟀殽",
        "format-alt": "{time} {icon}",
        "format-icons": {
            "default": [
                "蟀値",
                "蟀伜",
                "蟀伝",
                "蟀伡",
                "蟀伣",
                "蟀伨",
                "蟀伩",
                "蟀個",
                "蟀倎",
                "蟀倐",
                "蟀伖"
            ],
            "charging": [
                "蟀",
                "蟀",
                "蟀倖",
                "蟀倗",
                "蟀倛",
                "蟀",
                "蟀倝",
                "蟀",
                "蟀倞",
                "蟀倠",
                "蟀倕"
            ]
        }
    },
    "bluetooth": {
        "format": "蟀偗",
        "format-disabled": "",
        "format-connected": "蟀偙 {num_connections}",
        "tooltip-format": "{controller_alias}  {controller_address}",
        "tooltip-format-connected": "{controller_alias}\n\n{device_enumerate}",
        "tooltip-format-enumerate-connected": "{device_alias}  {device_address}",
        "on-click": "exec ghostty -e bluetui"
    },
    "network": {
        "format": "",
        "format-wifi": "蟀え",
        "format-ethernet": "蟀垁",
        "format-disconnected": "蟀き",
        "tooltip-format-wifi": "{essid} ({signalStrength}%) 蟀え",
        "tooltip-format-ethernet": "{ifname}  {ipaddr}/{cidr}",
        "tooltip-format-disconnected": "Disconnected"
    },
    "wireplumber": {
        "format": "{volume}% {icon}",
        "format-muted": "蟀潫 ",
        "format-icons": {
            "default": [
                "蟀暱",
                "蟀杸",
                "蟀暰"
            ]
        },
        "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle"
    },
    "backlight": {
        "device": "intel_backlight",
        "format": "{percent}% {icon}",
        "format-icons": [
            "蟀優",
            "蟀儬"
        ]
    },
    "tray": {
        "spacing": 10
    }
}
