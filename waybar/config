{
    "layer": "top",
    "height": 46,
    "spacing": 4,
    "modules-left": [
        "hyprland/workspaces"
    ],
    "modules-center": [
        "custom/cava",
        "custom/playerctl",
        "clock"
    ],
    "modules-right": [
        "hyprland/submap",
        "wireplumber",
        "backlight",
        "bluetooth",
        "network",
        "battery",
        "custom/language",
        "custom/notification",
        "tray"
    ],
    "hyprland/workspaces": {
        "format": "{id}",
        "on-click": "activate"
    },
    "hyprland/window": {
        "max-length": 60,
        "separate-outputs": true
    },
    "hyprland/submap": {
        "format": "<span size='x-large'>蟀毦</span> {}",
        "max-length": 12,
        "tooltip": false
    },
    "custom/language": {
        "exec": "hyprctl -j devices | jq -r '[.keyboards[] | select(.active_keymap != \"\")] | .[0].active_keymap | if . == \"Russian\" then \"RU\" else \"EN\" end'",
        "interval": 1,
        "format": "{}"
    },
    "clock": {
        "format": "<span size='x-large'>蟀</span> {:%a, %d %b  %I:%M %p}",
        "tooltip-format": "<tt><small>{calendar}</small></tt>",
        "calendar": {
            "format": {
                "today": "<span color='#7e9cd8'><b>{}</b></span>"
            }
        },
        "format-alt": "{:%Y-%m-%d}"
    },
    "battery": {
        "interval": 60,
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{capacity}% <span size='x-large'>{icon}</span>",
        "format-charging": "{capacity}% <span size='x-large'>{icon}</span>",
        "format-plugged": "{capacity}% <span size='x-large'>蟀殽</span>",
        "format-alt": "{time} <span size='x-large'>{icon}</span>",
        "format-icons": {
            "default": [
                "蟀値",
                "蟀伜",
                "蟀伝",
                "蟀伡",
                "蟀伣",
                "蟀伨",
                "蟀伩",
                "蟀個",
                "蟀倎",
                "蟀倐",
                "蟀伖"
            ],
            "charging": [
                "蟀",
                "蟀",
                "蟀倖",
                "蟀倗",
                "蟀倛",
                "蟀",
                "蟀倝",
                "蟀",
                "蟀倞",
                "蟀倠",
                "蟀倕"
            ]
        }
    },
    "bluetooth": {
        "format": "<span size='x-large'>蟀偗</span>",
        "format-disabled": "",
        "format-connected": "<span size='x-large'>蟀偙</span> {num_connections}",
        "tooltip-format": "{controller_alias}  {controller_address}",
        "tooltip-format-connected": "{controller_alias}\n\n{device_enumerate}",
        "tooltip-format-enumerate-connected": "{device_alias}  {device_battery_percentage}%  {device_address}",
        "on-click": "exec ghostty -e bluetui"
    },
    "network": {
        "format": "",
        "format-wifi": "<span size='x-large'>蟀え</span>",
        "format-ethernet": "<span size='x-large'>蟀垁</span>",
        "format-disconnected": "<span size='x-large'>蟀き</span>",
        "tooltip-format-wifi": "{essid} ({signalStrength}%) 蟀え",
        "tooltip-format-ethernet": "{ifname}  {ipaddr}/{cidr}",
        "tooltip-format-disconnected": "Disconnected"
    },
    "wireplumber": {
        "format": "{volume}% <span size='x-large'>{icon}</span>",
        "format-muted": "<span size='x-large'>蟀潫</span>",
        "format-icons": {
            "default": [
                "蟀暱",
                "蟀杸",
                "蟀暰"
            ]
        },
        "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle"
    },
    "backlight": {
        "device": "intel_backlight",
        "format": "{percent}% <span size='x-large'>{icon}</span>",
        "format-icons": [
            "蟀優",
            "蟀儬"
        ]
    },
    "tray": {
        "spacing": 10
    },
    "custom/cava": {
        "exec": "$HOME/.local/bin/cava-waybar",
        "return-type": "json",
        "format": "{}",
        "tooltip": false
    },
    "custom/playerctl": {
        "format": " {}",
        "return-type": "json",
        "max-length": 40,
        "exec": "playerctl -a metadata --format '{\"text\": \"{{artist}}  {{markup_escape(title)}}\", \"tooltip\": \"{{playerName}} : {{markup_escape(title)}}\", \"alt\": \"{{status}}\", \"class\": \"{{status}}\"}' -F",
        "on-click": "playerctl previous",
        "on-click-middle": "playerctl play-pause",
        "on-click-right": "playerctl next"
    }
}
