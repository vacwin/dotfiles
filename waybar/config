{
    "layer": "top",
    "height": 37,
    "spacing": 4,
    "modules-left": [
        "hyprland/workspaces"
    ],
    "modules-center": [
        "custom/cava",
        "custom/playerctl",
        "clock"
    ],
    "modules-right": [
        "hyprland/submap",
        "wireplumber",
        "backlight",
        "bluetooth",
        "network",
        "battery",
        "hyprland/language",
        "custom/notification",
        "tray"
    ],
    "hyprland/workspaces": {
        "format": "{id}",
        "on-click": "activate"
    },
    "hyprland/window": {
        "max-length": 60,
        "separate-outputs": true
    },
    "hyprland/submap": {
        "format": "σΑöΨ {}",
        "max-length": 12,
        "tooltip": false
    },
    "hyprland/language": {
        "format": "{short}"
    },
    "clock": {
        "format": "σΑΞî {:%a, %d %b  %I:%M %p}",
        "tooltip-format": "<tt><small>{calendar}</small></tt>",
        "calendar": {
            "mode": "month",
            "on-scroll": 1,
            "weeks-pos": "",
            "start-sunday": false,
            "format": {
                "today": "<span color='#7e9cd8'><b>{}</b></span>"
            }
        },
        "format-alt": "{:%Y-%m-%d}"
    },
    "battery": {
        "interval": 60,
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{capacity}% {icon}",
        "format-charging": "{capacity}% {icon}",
        "format-plugged": "{capacity}% σΑöΞ",
        "format-alt": "{time} {icon}",
        "format-icons": {
            "default": [
                "σΑ²é",
                "σΑ¹Κ",
                "σΑ¹Μ",
                "σΑ¹Φ",
                "σΑ¹Ϋ",
                "σΑ¹Ψ",
                "σΑ¹Ω",
                "σΑ²Ä",
                "σΑ²¹",
                "σΑ²²",
                "σΑ¹Ι"
            ],
            "charging": [
                "σΑΔü",
                "σΑΔ€",
                "σΑ²Ü",
                "σΑ²΅",
                "σΑ²à",
                "σΑΔù",
                "σΑ²â",
                "σΑΔû",
                "σΑ²ä",
                "σΑ²΄",
                "σΑ²Ö"
            ]
        }
    },
    "bluetooth": {
        "format": "σΑ²·",
        "format-disabled": "",
        "format-connected": "σΑ²± {num_connections}",
        "tooltip-format": "{controller_alias}  {controller_address}",
        "tooltip-format-connected": "{controller_alias}\n\n{device_enumerate}",
        "tooltip-format-enumerate-connected": "{device_alias}  {device_battery_percentage}%  {device_address}",
        "on-click": "exec ghostty -e bluetui"
    },
    "network": {
        "format": "",
        "format-wifi": "σΑΛ®",
        "format-ethernet": "σΑàÄ",
        "format-disconnected": "σΑΛ≠",
        "tooltip-format-wifi": "{essid} ({signalStrength}%) σΑΛ®",
        "tooltip-format-ethernet": "{ifname}  {ipaddr}/{cidr}",
        "tooltip-format-disconnected": "Disconnected"
    },
    "wireplumber": {
        "format": "{volume}% {icon}",
        "format-muted": "σΑùü ",
        "format-icons": {
            "default": [
                "σΑïΩ",
                "σΑ•Ä",
                "σΑïΨ"
            ]
        },
        "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle"
    },
    "backlight": {
        "device": "intel_backlight",
        "format": "{percent}% {icon}",
        "format-icons": [
            "σΑÉû",
            "σΑÉ†"
        ]
    },
    "tray": {
        "spacing": 10
    },
    "custom/cava": {
        "exec": "$HOME/.local/bin/cava-waybar",
        "return-type": "json",
        "format": "{}",
        "tooltip": false
    },
    "custom/playerctl": {
        "format": " {}",
        "return-type": "json",
        "max-length": 40,
        "exec": "playerctl -a metadata --format '{\"text\": \"{{artist}}  {{markup_escape(title)}}\", \"tooltip\": \"{{playerName}} : {{markup_escape(title)}}\", \"alt\": \"{{status}}\", \"class\": \"{{status}}\"}' -F",
        "on-click": "playerctl previous",
        "on-click-middle": "playerctl play-pause",
        "on-click-right": "playerctl next"
    }
}
