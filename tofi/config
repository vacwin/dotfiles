# Fonts
font = Iosevka Nerd Font
font-size = 14

# Window
width = 100%
height = 100%
background-color = #1f1f28
outline-width = 0
border-width = 0
padding-left = 35%
padding-top = 35%

# Text colors
text-color = #dcd7ba
prompt-text = "run: "
prompt-color = #7fb4ca
placeholder-text = ""
selection-color = #dcd7ba
selection-background = #2a2a37
selection-background-padding = 4

# Input
input-color = #dcd7ba
default-result-color = #727169

# Results
num-results = 8
result-spacing = 20

# Behavior
hide-cursor = true
history = true
fuzzy-match = true
