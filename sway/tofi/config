# Fonts
font = Iosevka Nerd Font
font-size = 14

# Window
width = 100%
height = 100%
background-color = #0d1a1f
outline-width = 0
border-width = 0
padding-left = 35%
padding-top = 35%

# Text colors
text-color = #a8c4c8
prompt-text = "run: "
prompt-color = #5abbc0
placeholder-text = ""
selection-color = #5abbc0
selection-background = #1e3840
selection-background-padding = 4

# Input
input-color = #e0f0f2
default-result-color = #5a9aaa

# Results
num-results = 8
result-spacing = 20

# Behavior
hide-cursor = true
history = true
fuzzy-match = true
